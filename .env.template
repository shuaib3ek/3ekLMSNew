# ─── Environment ─────────────────────────────────────────────────────────────
# LMS Database (completely separate from CRM)
LMS_DATABASE_URL=postgresql://lms_user:lms_password@localhost:5432/lms_db

# Flask
SECRET_KEY=change-me-in-production
FLASK_DEBUG=false
PORT=5001
BASE_URL=https://lms.3ek.in

# ─── CRM API Cross-Reference ──────────────────────────────────────────────────
# The LMS NEVER connects to the CRM database directly.
# All CRM entity lookups (Users, Clients, Contacts, Trainers) go via HTTP.
CRM_API_URL=https://app1.3ek.in
CRM_SERVICE_TOKEN=generate-a-strong-shared-secret-here

# Token used by CRM to call LMS endpoints
LMS_SERVICE_TOKEN=generate-a-strong-shared-secret-here

# ─── Microsoft Graph (Teams Recording Integration) ────────────────────────────
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_REDIRECT_URI=

# ─── AI ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── 3EK Course Studio API ───────────────────────────────────────────────────
COURSE_API_URL=http://localhost:8010

# ─── Razorpay (paid workshops) ────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Public Website ──────────────────────────────────────────────────────────
WEBSITE_BASE_URL=https://www.3ek.in
